@model Gemini.Models.PosPaymentQr

@{
    ViewBag.Title = Model.Guid == Guid.Empty ? "Th&#234;m m&#7899;i QR" : "C&#7853;p nh&#7853;t QR";
    Layout = "~/Views/Shared/_FormList.cshtml";
}

<div id="main-content">
    <div class="row">
        <div class="col-md-12">
            @using (Html.BeginForm("Create", "PaymentQr", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.HiddenFor(m => m.Guid)
                @Html.HiddenFor(m => m.CreatedAt)
                @Html.HiddenFor(m => m.CreatedBy)

                <div class="form-group">
                    <label class="control-label col-md-2">M&#227; ng&#226;n h&#224;ng (Bin/Code)</label>
                    <div class="col-md-4">
                        @Html.TextBoxFor(m => m.BankCode, new { @class = "form-control", @placeholder = "VD: MB, VCB", @required = "required" })
                        <em class="text-muted">Nh&#7853;p m&#227; ng&#226;n h&#224;ng (VD: 970422 cho MB, ho&#7863;c MB, VCB...)</em>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">T&#234;n ng&#226;n h&#224;ng</label>
                    <div class="col-md-4">
                        @Html.TextBoxFor(m => m.BankName, new { @class = "form-control" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">S&#7889; t&#224;i kho&#7843;n</label>
                    <div class="col-md-4">
                        @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control", @required = "required" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">T&#234;n ch&#7911; TK</label>
                    <div class="col-md-4">
                        @Html.TextBoxFor(m => m.AccountName, new { @class = "form-control" })
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="control-label col-md-2">Template</label>
                    <div class="col-md-4">
                        @Html.TextBoxFor(m => m.Template, new { @class = "form-control", @placeholder = "compact, qr_only..." })
                         <em class="text-muted">M&#7863;c &#273;&#7883;nh: compact</em>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">K&#237;ch ho&#7841;t</label>
                    <div class="col-md-4">
                        @Html.CheckBoxFor(m => m.Active)
                        <br/>
                        <em class="text-info">L&#432;u &#253;: C&#243; th&#7875; ch&#7881; c&#243; 1 m&#227; &#273;&#432;&#7907;c k&#237;ch ho&#7841;t c&#249;ng l&#250;c.</em>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">Ghi ch&#250;</label>
                    <div class="col-md-8">
                        @Html.TextAreaFor(m => m.Note, new { @class = "form-control", rows = 3 })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <button type="submit" class="btn btn-primary">L&#432;u l&#7841;i</button>
                        <a href="@Url.Action("Index", "PaymentQr")" class="btn btn-default">H&#7911;y b&#7887;</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
