                            {
                                command.Edit().Text("Sửa");
                                command.Destroy().Text("Xóa");
                            }).Width(180);
                        })
                        .ToolBar(toolbar =>
                        {
                            toolbar.Create().Text("Thêm mới");
                        })
                        .Editable(editable => editable.Mode(GridEditMode.InLine))
                        .Pageable(pageable => pageable.PageSizes(new[] { 10, 20, 50, 100 }))
                        .Sortable()
                        .Filterable()
                        .DataSource(dataSource => dataSource
                            .Ajax()
                            .PageSize(20)
                            .Model(model =>
                            {
                                model.Id(p => p.Guid);
                                model.Field(p => p.Guid).Editable(false).DefaultValue(Guid.Empty);
                                model.Field(p => p.GuidProduce).Editable(false).DefaultValue(Model.Guid);
                                model.Field(p => p.Size);
                                model.Field(p => p.Color);
                                model.Field(p => p.Quantity).DefaultValue(0);
                                model.Field(p => p.UpdatedAt).Editable(false);
                            })
                            .Read(read => read.Action("ReadInventory", "PosProduce", new { guidProduce = Model.Guid }))
                            .Create(create => create.Action("CreateInventory", "PosProduce").Data("additionalData"))
                            .Update(update => update.Action("UpdateInventory", "PosProduce"))
                            .Destroy(destroy => destroy.Action("DeleteInventory", "PosProduce"))
                        )
                    )

<script>
    function additionalData() {
        return {
            GuidProduce: '@Model.Guid'
        };
    }

    var sizes = [];
    var colors = [];

    // Parse Size and Color from Model
    $(document).ready(function() {
        var sizeStr = "@Html.Raw(Model.Size)";
        var colorStr = "@Html.Raw(Model.Color)";

        if (sizeStr) {
            sizes = sizeStr.split(',').map(function(item) {
                return { text: item.trim(), value: item.trim() };
            });
        }

        if (colorStr) {
            colors = colorStr.split(',').map(function(item) {
                return { text: item.trim(), value: item.trim() };
            });
        }
    });


    function onGridEdit(e) {
        if (!e.model.isNew()) {
            // Optional: Disable auditing fields if needed
        }

        // Use setTimeout to allow Kendo to finish rendering the input cell
        setTimeout(function() {
            // Initialize Size Dropdown
            var sizeInput = e.container.find("input[name=Size]");
            if (sizeInput.length === 0) {
                 // Try to find by attribute data-bind="value:Size" if name is missing
                 sizeInput = e.container.find("[data-bind='value:Size']");
            }

            if (sizeInput.length > 0) {
                // Determine if it is already a widget
                if (!sizeInput.data("kendoDropDownList")) {
                    sizeInput.kendoDropDownList({
                        dataTextField: "text",
                        dataValueField: "value",
                        dataSource: sizes,
                        optionLabel: "-- Chọn Size --",
                        change: function(e) {
                            // Force update model
                            var grid = $("#gridInventory").data("kendoGrid");
                            var item = grid.dataItem(this.element.closest("tr"));
                            item.set("Size", this.value());
                        }
                    });
                }
            } else {
                console.log("Size input not found!");
            }

            // Initialize Color Dropdown
            var colorInput = e.container.find("input[name=Color]");
            if (colorInput.length === 0) {
                 colorInput = e.container.find("[data-bind='value:Color']");
            }

            if (colorInput.length > 0) {
                if (!colorInput.data("kendoDropDownList")) {
                    colorInput.kendoDropDownList({
                        dataTextField: "text",
                        dataValueField: "value",
                        dataSource: colors,
                        optionLabel: "-- Chọn Màu --",
                        change: function(e) {
                            var grid = $("#gridInventory").data("kendoGrid");
                            var item = grid.dataItem(this.element.closest("tr"));
                            item.set("Color", this.value());
                        }
                    });
                }
            } else {
                 console.log("Color input not found!");
            }
        }, 100);
    }

    function addInventoryRow() {
        var grid = $("#gridInventory").data("kendoGrid");
        grid.addRow();
    }

    function saveInventory() {
        var grid = $("#gridInventory").data("kendoGrid");
        grid.saveChanges();
    }
</script>
