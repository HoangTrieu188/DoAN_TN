                    @(Html.Kendo().Grid<Gemini.Models.PosInventory>()
                        .Name("gridInventory")
                        .Events(e => e.Edit("onGridEdit"))
                        .Columns(columns =>
                        {
                            columns.Bound(p => p.Size).Title("Size").Width(150);
                            columns.Bound(p => p.Color).Title("Màu sắc").Width(150);
                            columns.Bound(p => p.Quantity).Title("Số lượng").Width(120).Format("{0:n0}");
                            columns.Bound(p => p.UpdatedAt).Title("Cập nhật").Width(150).Format("{0:dd/MM/yyyy HH:mm}");
